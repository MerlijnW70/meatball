# Voorbeeld voor lokale dev. Kopieer naar .env.local (niet commit — .gitignore skipt 'm).
# Defaults in connect.ts zijn: ws://localhost:3000 + "meatball", dus dit bestand
# is alleen nodig als je lokaal een andere SDB-instance draait.

# VITE_STDB_HOST=ws://localhost:3000
# VITE_STDB_MODULE=meatball

# Offline mock mode (geen echte server vereist, zet op 1 om store manueel te laden):
# VITE_MOCK=1
